# Shopify Storefront API configuration
# Store domain, e.g. your-store.myshopify.com
SHOPIFY_DOMAIN=6c6a1d-39.myshopify.com

# Shopify Storefront API version
SHOPIFY_API_VERSION=2025-01

# Storefront API public token from Shopify Admin > Headless
STOREFRONT_PUBLIC_TOKEN=your_storefront_public_token_here

# Optional: enable server-side Shopify diagnostics logs
SHOPIFY_DEBUG=false

# Optional analytics IDs
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Optional commerce configuration
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=99
NEXT_PUBLIC_RETURNS_WARRANTY_COPY=30-day returns on unused gear. Lifetime steel workmanship guarantee.
